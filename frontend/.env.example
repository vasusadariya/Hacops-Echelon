# PostgreSQL connection string (replaces the old MONGODB_URI)
DATABASE_URL="postgresql://user:password@localhost:5432/hackops_echelon"

# Sign a long random string for production — this file has a dev-only fallback
# if unset, but every route must be able to see the SAME value or tokens signed
# by one instance won't verify on another.
JWT_SECRET="change-me"

# Cloudinary (document/selfie image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail (or any SMTP-compatible) account used to send password-reset emails
EMAIL_USER=
EMAIL_PASSWORD=

# FastAPI ML backend base URL
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"

# This app's own public base URL — used for self-referencing server-to-server
# calls (e.g. triggering /api/verification/ai-process after submit) and for
# building password-reset links. NEXTAUTH_URL is read as a fallback for the
# same purpose in a couple of places.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Google reCAPTCHA v3 site key (client-side only — there is currently no
# server-side secret/verification wired up)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
