# Required — Roboflow API key used by the Aadhaar entity-detection endpoint
# (backend/models/ocraadhar.py). The key that was previously hardcoded in that
# file should be treated as leaked and rotated before use.
ROBOFLOW_API_KEY=

# Optional — comma-separated list of allowed CORS origins for the frontend(s)
# calling this API directly. Defaults to the local dev origins if unset.
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
